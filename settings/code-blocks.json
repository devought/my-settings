{
	"Fast Console Log": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue,html,svelte",
		"prefix": "cl",
		"body": "console.log($0);",
		"description": "Fast console.log"
	},
	"Debug log (labeled)": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue,svelte",
		"prefix": "cd",
		"body": "console.log('$1:', $1);",
		"description": "Debug log with variable label"
	},
	"Destructure rename": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue,svelte",
		"prefix": "dr",
		"body": "const { $2 } = $1;",
		"description": "Object destructuring with rename"
	},
	"Traditional for loop": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact",
		"prefix": "defor",
		"body": ["for (let i = 0; i < $1; i++) {", "  $2", "}"],
		"description": "Traditional indexed for loop"
	},
	"Frequency Map Increment": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact",
		"prefix": "req",
		"body": ["$1.set($2, ($1.get($2) ?? 0) + 1)"],
		"description": "Increment a frequency map entry. Tab 1 = map name, Tab 2 = array name."
	},
	"Divider": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact, markdown",
		"prefix": "div",
		"body": "----------------------------------------- Divider -----------------------------------------",
		"description": "Simple divider for better readability"
	},
	"Swapper": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue,html",
		"prefix": "wap",
		"body": ";[$1[i],$1[j]] = [$1[j], $1[i]]"
	},
	"Odd": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue,html",
		"prefix": "odd",
		"body": "$1 & 1"
	},
	"Even": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue,html",
		"prefix": "ven",
		"body": "$1 % 2 == 0"
	},
	"Math.max": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue",
		"prefix": "max",
		"body": "Math.max($0)"
	},
	"Math.min": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue",
		"prefix": "min",
		"body": "Math.min($0)"
	},
	"Math.abs": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue",
		"prefix": "mas",
		"body": "Math.abs($1)"
	},
	"Math.floor": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue",
		"prefix": "flr",
		"body": "Math.floor($1)"
	},
	"Math.ceil": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact,vue",
		"prefix": "cel",
		"body": "Math.floor($1)"
	},
	"Convert to Number": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact",
		"prefix": "cn",
		"body": "Number($1)"
	},
	"Convert to String": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact",
		"prefix": "cs",
		"body": "String($1)"
	},
	"Convert to Boolean": {
		"scope": "typescript,javascript,typescriptreact,javascriptreact",
		"prefix": "cb",
		"body": "Boolean($1)"
	}
}
